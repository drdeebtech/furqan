{
  "name": "furqan",
  "version": "0.1.1",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke:sentry-watch": "node --env-file=.env.local scripts/sentry-watch-smoke.mjs",
    "vercel:ls": "vercel ls furqan --prod",
    "db:types": "supabase gen types typescript --linked > src/types/supabase.generated.ts",
    "sb:whoami": "bash scripts/sb/whoami.sh",
    "sb:sql": "bash scripts/sb/sql.sh",
    "sb:user": "bash scripts/sb/find-user.sh",
    "sb:reset-pw": "bash scripts/sb/reset-password.sh",
    "sb:errors": "bash scripts/sb/auth-errors.sh",
    "sb:inspect": "bash scripts/sb/inspect.sh",
    "sb:advisors": "bash scripts/sb/advisors.sh",
    "sb:grants": "bash scripts/sb/grants.sh",
    "sb:tables": "bash scripts/sb/tables.sh",
    "sb:backup": "bash scripts/sb/backup.sh",
    "specs:index": "tsx scripts/generate-specs-index.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "specs/**/*.md": [
      "bash -c 'npm run specs:index && git add specs/INDEX.md'"
    ]
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.90.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@hookform/resolvers": "^5.4.0",
    "@paypal/react-paypal-js": "^10.0.0",
    "@react-email/render": "^2.0.8",
    "@sentry/nextjs": "^10.56.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/functions": "^3.6.3",
    "@vercel/speed-insights": "^2.0.0",
    "botid": "^1.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "globals": "^17.6.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.78.0",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "resend": "^6.1.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "tus-js-client": "^4.3.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@sentry/cli": "^3.5.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.0",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.7",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
