{
  "name": "furqan",
  "version": "0.1.2",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke:sentry-watch": "node --env-file=.env.local scripts/sentry-watch-smoke.mjs",
    "vercel:ls": "vercel ls furqan --prod",
    "db:types": "supabase gen types typescript --linked > src/types/supabase.generated.ts",
    "sb:whoami": "bash scripts/sb/whoami.sh",
    "sb:sql": "bash scripts/sb/sql.sh",
    "sb:user": "bash scripts/sb/find-user.sh",
    "sb:reset-pw": "bash scripts/sb/reset-password.sh",
    "sb:errors": "bash scripts/sb/auth-errors.sh",
    "sb:inspect": "bash scripts/sb/inspect.sh",
    "sb:advisors": "bash scripts/sb/advisors.sh",
    "sb:grants": "bash scripts/sb/grants.sh",
    "sb:tables": "bash scripts/sb/tables.sh",
    "sb:backup": "bash scripts/sb/backup.sh",
    "specs:index": "tsx scripts/generate-specs-index.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "specs/**/*.md": [
      "bash -c 'npm run specs:index && git add specs/INDEX.md'"
    ]
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.91.0",
    "@eslint/compat": "^2.1.0",
    "@hookform/resolvers": "^5.4.0",
    "@sentry/nextjs": "^10.65.0",
    "@sparticuz/chromium": "^149.0.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/functions": "^3.7.5",
    "@vercel/speed-insights": "^2.0.0",
    "botid": "^1.5.11",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "posthog-js": "^1.399.2",
    "posthog-node": "^5.41.0",
    "puppeteer-core": "^25.3.0",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.6.0",
    "tus-js-client": "^4.3.1",
    "web-push": "^3.6.7",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.0",
    "@sentry/cli": "^3.6.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.4.0",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^6",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "@opentelemetry/core": "2.8.0",
    "webpack-bundle-analyzer": {
      "ws": "7.5.11"
    }
  }
}
