{
  "_comment": "Copy to .mcp.json (gitignored). Replace the Perplexity args path with your Perplexity MCP start script.",
  "mcpServers": {
    "Sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp/furqan-academy/javascript-nextjs-e4"
    },
    "Perplexity": {
      "command": "/usr/local/bin/node",
      "args": ["${userHome}/.perplexity-mcp/start.mjs"],
      "env": {
        "PERPLEXITY_HEADLESS_ONLY": "1"
      },
      "type": "stdio"
    }
  }
}
