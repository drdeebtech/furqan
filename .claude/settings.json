{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "TaskCreate",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dg-pre-task-create-naming.sh"
					}
				]
			}
		],
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dg-check-stale-sentinel.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dg-verify-acceptance-criteria.sh"
					}
				]
			}
		],
		"TaskCompleted": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/dg-task-completed-validate.sh"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": ".claude/statusline.sh",
		"padding": 0
	},
	"permissions": {
		"deny": [
			"Read(./.env)",
			"Read(./.env.*)"
		]
	}
}