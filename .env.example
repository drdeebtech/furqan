# FURQAN Academy — environment variables reference
# Copy to .env.local and fill in your values.
# Full description of each variable: docs/agents/env-vars.md

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:support@furqan.today
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# ── Daily.co (video sessions) ────────────────────────────────────────────────
DAILY_API_KEY=your_daily_api_key
DAILY_WEBHOOK_SECRET=your_daily_webhook_hmac_secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@furqan.today
ADMIN_EMAIL=admin@furqan.today

# ── n8n automation ────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://n8n.your-host.tech
N8N_WEBHOOK_SECRET=your_n8n_webhook_secret
N8N_API_URL=https://n8n.your-host.tech/api/v1
N8N_API_KEY=your_n8n_api_key
N8N_HEALTHCHECK_URL=https://n8n.your-host.tech/healthz
NEXT_PUBLIC_N8N_UI_URL=https://n8n.your-host.tech

# Mixpanel product analytics (client-public project token, not a secret).
# Unset = analytics disabled (fail-soft).
NEXT_PUBLIC_MIXPANEL_TOKEN=

# ── Telegram (admin alerts) ───────────────────────────────────────────────────
TG_BOT_TOKEN=your_telegram_bot_token
TG_ADMIN_CHAT_ID=your_telegram_chat_id

# ── Cron authentication ───────────────────────────────────────────────────────
CRON_SECRET=your_cron_bearer_secret

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_key@o0.ingest.de.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_key@o0.ingest.de.sentry.io/0
SENTRY_WATCH_SECRET=your_sentry_watch_secret


# ── Bunny.net (Edge Storage — PDF certificates, spec 031) ────────────────────
# Storage zone credentials (server-only — never NEXT_PUBLIC_*)
BUNNY_STORAGE_ZONE_NAME=your_storage_zone_name
BUNNY_STORAGE_API_KEY=your_storage_zone_password
BUNNY_STORAGE_HOSTNAME=your-pull-zone.b-cdn.net
BUNNY_STORAGE_REGION_ENDPOINT=storage.bunnycdn.com

# ── Bunny.net (video streaming) ───────────────────────────────────────────────
BUNNY_STREAM_API_KEY=your_bunny_stream_key
BUNNY_STREAM_LIBRARY_ID=12345678
BUNNY_STREAM_PULL_ZONE_HOSTNAME=vz-00000000-abc.b-cdn.net
BUNNY_STREAM_TOKEN_AUTH_KEY=your_bunny_token_auth_key
BUNNY_WEBHOOK_SECRET=your_bunny_webhook_secret

# ── PayPal (payments) ─────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# ── Stripe (deferred) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── WhatsApp routing (CallMeBot) ──────────────────────────────────────────────
CALLMEBOT_KEY_EG=your_callmebot_key_egypt
CALLMEBOT_KEY_KW=your_callmebot_key_kuwait
CALLMEBOT_PHONE_EG=+201XXXXXXXXX
CALLMEBOT_PHONE_KW=+965XXXXXXXX

# ── Misc ──────────────────────────────────────────────────────────────────────
BOTID_BYPASS_EMAILS=admin@furqan.today

# ── Vercel (CI/CD) ────────────────────────────────────────────────────────────
# Set in GitHub Actions secrets, not locally.
VERCEL_TOKEN=your_vercel_access_token
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id
