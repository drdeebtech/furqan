# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
testsprite_tests/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
verification/
.env*.local
supabase/.temp/
supabase/.branches/
.gitnexus

# Local MCP configs (machine-specific paths; copy from .mcp.json.example)
.mcp.json
.idx/

# claude runtime artifacts (machine-specific config and transient state ignored;
# local skill installs are tracked separately under .claude/skills/ below)
.claude/settings.json
.claude/scheduled_tasks.lock
.claude/plans/
.claude/worktrees/

# local tooling symlinks (ruflo ADR detection — not project source)
docs/adrs

# Jules AI agent tracking files (machine-generated, not source)
.Jules/

# Sentry Config File
.env.sentry-build-plugin

# Supabase admin script outputs (DB dumps + reports)
/backups/

# k6 test data fixtures + results (contain real test-user passwords and
# JWT session tokens — must never be committed). The runner scripts and
# *.js test files ARE tracked; only the generated data is ignored.
/k6/students-credentials.csv
/k6/teachers-credentials.csv
/k6/admins-credentials.csv
/k6/moderators-credentials.csv
/k6/student-sessions.json
/k6-results.json
/k6-app-results.json
/k6-auth-edge-results.json
/k6-teacher-results.json
/k6-admin-results.json
/k6-moderator-results.json

# understand-anything knowledge graph + audit tooling (local only)
.understand-anything/

# Graphify (code-graph generator) local output — large generated artifacts
# (graph.json/html, manifest, chunk + community caches). Not project source.
graphify-out/

# AI tooling runtime state (local only — must not be committed/published)
.swarm/
.claude-flow/

# Local AI-tooling skill installs (not product)
.agents/
.claude/skills/
skills-lock.json

# ruflo / claude-flow init artifacts (machine-local tooling, not project code)
.claude/agents/
.claude/commands/agents/
.claude/commands/analysis/
.claude/commands/coordination/
.claude/commands/github/
.claude/commands/hive-mind/
.claude/commands/hooks/
.claude/commands/memory/
.claude/commands/monitoring/
.claude/commands/optimization/
.claude/commands/pair/
.claude/commands/sparc/
.claude/commands/stream-chain/
.claude/commands/swarm/
.claude/commands/training/
.claude/commands/truth/
.claude/commands/verify/
.claude/commands/workflows/
.claude/commands/claude-flow-*.md

# Internal n8n automation ops (removed for public repo; keep the nightly
# n8n-export from re-publishing workflow JSON / runbooks to this public repo)
automation/

# ECC (Everything Claude Code) — large external tooling repo, not project source
ECC/
.gstack/

# Stray debug-capture dumps (large, machine-generated, never source).
# Patterns catch *_head.txt / *_output.txt at repo root so future ad-hoc
# captures don't sneak in.
/db_head.txt
/gen_head.txt
/lint_output.txt
/*_head.txt
/*_output.txt

testsprite_tests/tmp/config.json

# Backup/temp copies — git is the backup; these are how secrets leak.
# (.env.local.prod.bak + settings.local.json.bak both carried live keys.)
*.bak
*.orig
*.save
.claude/*.bak

# Per-developer AI-assistant tool configs (redundant with AGENTS.md, the
# single source of truth). Kept on disk for the tools, out of git.
.cursorrules
.cursor/
.codebuddy/
.kiro/
.hermes.md
