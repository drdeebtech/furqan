# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
verification/
.env*.local
supabase/.temp/
.gitnexus

# Local MCP configs (machine-specific paths; copy from .mcp.json.example)
.mcp.json
.idx/

# claude runtime artifacts (keep skills tracked, ignore transient state)
.claude/scheduled_tasks.lock
.claude/plans/

# Jules AI agent tracking files (machine-generated, not source)
.Jules/

# Sentry Config File
.env.sentry-build-plugin

# Supabase admin script outputs (DB dumps + reports)
/backups/

# k6 test data fixtures + results (contain real test-user passwords and
# JWT session tokens — must never be committed). The runner scripts and
# *.js test files ARE tracked; only the generated data is ignored.
/k6/students-credentials.csv
/k6/teachers-credentials.csv
/k6/admins-credentials.csv
/k6/moderators-credentials.csv
/k6/student-sessions.json
/k6-results.json
/k6-app-results.json
/k6-auth-edge-results.json
/k6-teacher-results.json
/k6-admin-results.json
/k6-moderator-results.json

# understand-anything knowledge graph + audit tooling (local only)
.understand-anything/

# AI tooling runtime state (local only — must not be committed/published)
.swarm/
.claude-flow/

# Local AI-tooling skill installs (not product)
.agents/
.claude/skills/
skills-lock.json

# Internal n8n automation ops (removed for public repo; keep the nightly
# n8n-export from re-publishing workflow JSON / runbooks to this public repo)
automation/

# ECC (Everything Claude Code) — large external tooling repo, not project source
ECC/
.gstack/

testsprite_tests/tmp/
